# ============================================================
# DJANGO
# ============================================================
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=False
ALLOWED_HOSTS=cieloapi.lambdaanalytics.co,localhost,127.0.0.1

# ============================================================
# POSTGRESQL
# ============================================================
DB_NAME=cielo_db
DB_USER=cielo_user
DB_PASS=tu-password
DB_HOST=localhost
DB_PORT=5432

# ============================================================
# MICROSOFT GRAPH (correos corporativos)
# ============================================================
CORREO_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CORREO_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
CORREO_SECRET_KEY=tu-client-secret
EMAIL_HOST_USER=correo@fincaelcielo.com

# ============================================================
# SUPPLOS API (ERP pedidos)
# ============================================================
SUPLOS_API_URL=https://apicoronaqas.suplos.com
SUPLOS_API_EMAIL=usuario@suplos.com
SUPLOS_API_PASSWORD=tu-password

# ============================================================
# AZURE OPENAI
# ============================================================
AZURE_OPENAI_ENDPOINT=https://tu-recurso.openai.azure.com/
AZURE_OPENAI_API_KEY=tu-api-key

# Modelo estructurador (extraccion de correos/PDFs)
AZURE_OPENAI_STRUCTURING_DEPLOYMENT=gpt-4.1-structuring-suplos
AZURE_OPENAI_STRUCTURING_API_VERSION=2025-01-01-preview

# Modelo orquestador (agente principal)
AZURE_OPENAI_ORCHESTRATOR_DEPLOYMENT=gpt-5.2-chat-orchestrator-suplos
AZURE_OPENAI_ORCHESTRATOR_API_VERSION=2025-04-01-preview

# OpenAI directo (fallback busqueda IA)
OPENAI_API_KEY=sk-tu-api-key
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# AZURE DOCUMENT INTELLIGENCE (OCR PDFs e imagenes)
# ============================================================
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://tu-recurso.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=tu-api-key

# ============================================================
# CELERY + REDIS (no cambiar si usas Docker Compose)
# ============================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================================
# CORS
# ============================================================
CORS_ALLOWED_ORIGINS=https://cieloapi.lambdaanalytics.co,http://localhost:3000
